          "name": "List Communications",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/crm/communications?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "crm", "communications"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "channel", "value": "email", "disabled": true },
                { "key": "status", "value": "sent", "disabled": true },
                { "key": "contact_id", "value": "", "disabled": true }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Communication Status",
          "request": {
            "method": "PATCH",
