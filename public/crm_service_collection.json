{
  "info": {
    "_postman_id": "crm-service-collection",
    "name": "CRM Service API",
    "description": "Standalone CRM Service - All endpoints are PUBLIC (no auth required).\n\nIncludes:\n- Contacts\n- Inquiries/Leads\n- Feedback\n- Support Tickets\n- Communications",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Inquiries",
      "description": "Lead/inquiry management endpoints",
      "item": [
        {
          "name": "Create Inquiry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone_number\": \"+27821234567\",\n  \"username\": \"johnd\",\n  \"venue_type\": \"restaurant\",\n  \"tenant_type\": \"independent\",\n  \"description\": \"Looking for a POS system\",\n  \"message\": \"I have a small restaurant with 10 tables.\",\n  \"source\": \"website\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/crm/inquiries",
              "host": ["{{baseUrl}}"],
              "path": ["api", "crm", "inquiries"]
            }
          },
          "response": []
        },
        {
          "name": "List Inquiries",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/crm/inquiries?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "crm", "inquiries"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "new", "disabled": true },
                { "key": "venue_type", "value": "restaurant", "disabled": true }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Inquiry by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/crm/inquiries/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "crm", "inquiries", ":id"],
              "variable": [
                { "key": "id", "value": "{{inquiry_id}}" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Inquiry Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"contacted\",\n  \"assigned_to\": \"sales@company.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/crm/inquiries/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "crm", "inquiries", ":id", "status"],
              "variable": [
                { "key": "id", "value": "{{inquiry_id}}" }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Feedback",
