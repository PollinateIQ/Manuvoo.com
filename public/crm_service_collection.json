          "name": "Update Support Ticket Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\",\n  \"assigned_to\": \"support@company.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/crm/support-tickets/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "crm", "support-tickets", ":id", "status"],
              "variable": [
                { "key": "id", "value": "{{ticket_id}}" }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Communications",
      "description": "Communication log endpoints (emails, SMS, etc.)",
      "item": [
        {
          "name": "Create Communication (Email)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"channel\": \"email\",\n  \"direction\": \"outbound\",\n  \"subject\": \"Welcome to our platform\",\n  \"payload_json\": {\n    \"to\": \"john.doe@example.com\",\n    \"from\": \"support@company.com\",\n    \"body\": \"Thank you for your inquiry.\",\n    \"html\": \"<p>Thank you for your inquiry.</p>\"\n  },\n  \"status\": \"sent\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/crm/communications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "crm", "communications"]
            }
          },
          "response": []
        },
        {
          "name": "Create Communication (SMS)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"channel\": \"sms\",\n  \"direction\": \"outbound\",\n  \"payload_json\": {\n    \"to\": \"+27821234567\",\n    \"body\": \"Your support ticket has been received.\"\n  },\n  \"status\": \"pending\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/crm/communications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "crm", "communications"]
            }
          },
          "response": []
        },
