            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Great platform! Easy to use.\",\n  \"full_name\": \"Happy Customer\",\n  \"email\": \"happy@example.com\",\n  \"rating\": 5,\n  \"category\": \"product\",\n  \"subject\": \"Excellent Experience\",\n  \"is_public\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/crm/feedback",
              "host": ["{{baseUrl}}"],
              "path": ["api", "crm", "feedback"]
            }
          },
          "response": []
        },
        {
          "name": "Create Feedback (Anonymous)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Please add dark mode.\",\n  \"rating\": 4,\n  \"category\": \"feature_request\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/crm/feedback",
              "host": ["{{baseUrl}}"],
              "path": ["api", "crm", "feedback"]
            }
          },
          "response": []
        },
        {
          "name": "List Feedback",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/crm/feedback?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "crm", "feedback"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "category", "value": "product", "disabled": true },
                { "key": "min_rating", "value": "4", "disabled": true }
              ]
            }
          },
          "response": []
        }
      ]
    },
