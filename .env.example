# Backend API Configuration
# Production API URL
VITE_API_BASE_URL=https://api.manuvoo.com

# Use mock API for development (optional)
VITE_USE_MOCK_API=false

# WhatsApp Business Cloud API Configuration (Legacy - used by backend)
# Get these from: https://developers.facebook.com/apps/

# Your WhatsApp Business Phone Number ID (found in WhatsApp Business API settings)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Your permanent access token (generate in Meta Business settings)
WHATSAPP_ACCESS_TOKEN=your_access_token_here

# Your WhatsApp number to receive messages (format: country code + number, no spaces or +)
# Example: For +27 69 684 8796, use: 27696848796
WHATSAPP_RECIPIENT_NUMBER=27696848796
